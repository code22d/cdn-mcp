# Dependencies — never commit; macOS/Linux native binaries diverge
node_modules/

# Wrangler local cache + dev secrets
.wrangler/
.dev.vars
.dev.vars.*

# Local secrets (per Phase 0 hygiene rule — never commit a token file)
mcp_auth_token*.txt
mcp_auth_token*

# Defensive: env files, key material, packaged tarballs — never commit
.env
.env.*
*.secret
*.pem
*.key
*.tgz

# Build/output (we don't generate these in this project, but defensive)
dist/
build/
out/

# Editor / OS clutter
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary test fixtures (Phase 4 large-file test artifacts)
/tmp/phase*-fixture*
*.bin.tmp
skills/*-workspace/

# Phase 7 — Cowork plugin build artifacts
# The .plugin file is built from plugin/ + canonical skills/ at release time.
# plugin/skills/ is populated by build.sh from the canonical skills/ source.
cdn-mcp-plugin.plugin
plugin/skills/
