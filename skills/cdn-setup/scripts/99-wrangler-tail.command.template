#!/bin/bash
# Auto-generated by cdn-setup skill — optional debug affordance.
# Live-streams the deployed Worker's logs so you can watch requests arrive
# in real time (e.g., what claude.ai sends when adding the custom connector,
# or why a smoke test failed). Offered on request only — never auto-run.

set -e
export PATH="$HOME/.npm-global/bin:$PATH"

CLONE_DIR="$HOME/cdn-mcp"

if [ ! -d "$CLONE_DIR" ]; then
  echo "✗ $CLONE_DIR not found — the Phase C deploy script clones the repo there."
  echo "  Run 02-deploy-worker.command first."
  read -n 1 -s -r -p "Press any key to close..."
  exit 1
fi

cd "$CLONE_DIR"
echo "Streaming live Worker logs. Reproduce the failing action now"
echo "(e.g., re-add the connector at claude.ai) and watch the requests below."
echo "Press Ctrl-C to stop."
echo ""
npx wrangler tail
